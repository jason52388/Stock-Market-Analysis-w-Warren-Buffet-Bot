# Copy this file to .env on the VPS and fill in real values.
# `chmod 600 .env` after editing — it contains credentials.

# ---- Schedule ----
# Container timezone. Affects when the cron line in deploy/crontab fires.
TZ=America/New_York

# ---- Public website ----
# Hostname Caddy serves. Must resolve publicly for HTTPS to work
# (Let's Encrypt needs to reach :80). For Hostinger-provided hostnames,
# use whatever Hostinger shows in the VPS control panel.
SITE_HOSTNAME=your-vps-hostname.hstgr.cloud

# ---- Gmail SMTP ----
GMAIL_FROM=you@gmail.com
GMAIL_TO=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ---- Notion ----
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
