# Serves the site on both the bare domain and www. The apex redirects to www
# (the canonical address), so links and the cert stay consistent. Caddy
# auto-provisions Let's Encrypt certs for BOTH names — which requires BOTH
# yalamanstockmarket.com and www.yalamanstockmarket.com to have DNS A records
# pointing at this VPS (177.7.58.66).
#
# Hostnames are hardcoded (not {$SITE_HOSTNAME}) so an empty/missing env var
# can never produce an invalid empty site address that crashes Caddy.

# Bare domain -> redirect to www, preserving the path/query.
yalamanstockmarket.com {
    redir https://www.yalamanstockmarket.com{uri} permanent
}

# www -> the actual site.
www.yalamanstockmarket.com {
    root * /srv
    encode gzip

    # Archive first, in its own handle block. This MUST come before the
    # site-root fallback below: a bare `try_files {path} /index.html` rewrites
    # /archive/ to /index.html (try_files doesn't match the directory), and
    # since matchers see the rewritten path, the archive index never gets
    # served. An isolated `handle` is mutually exclusive, so /archive/ is
    # routed here and file_server serves archive/index.html (the "Past runs"
    # page built by build-index.sh), with `browse` as a fallback listing for
    # any sub-path without an index.
    @archive path /archive /archive/*
    handle @archive {
        file_server browse
    }

    # Everything else: the site root is the latest run — build-index.sh copies
    # the freshest dashboard to index.html after each run, so "/" shows it
    # directly. Unknown paths fall back to it; explicit files are served as-is,
    # so stray files in out/ (debug CSVs, scratch files) aren't exposed.
    handle {
        try_files {path} /index.html
        file_server
    }

    # Light caching for HTML (so a redeploy shows new content within a minute).
    header /*.html Cache-Control "public, max-age=60"
    header /archive/* Cache-Control "public, max-age=3600"
}

# ─────────────────────────────────────────────────────────────
#  YalamanBaby site (a separate project living on the same VPS)
#
#  The baby app runs in its own Docker container (yalaman-baby) that binds
#  127.0.0.1:8088 on the host. This Caddy reaches it via the Docker bridge
#  gateway (172.17.0.1:8088). Adding these blocks is the ONLY way HTTPS for
#  yalamanbaby.com can work on this VPS, since warren-caddy is the only
#  process holding ports 80/443.
#
#  Repo: https://github.com/jason52388/YalamanBaby
#  DNS:  yalamanbaby.com AND www.yalamanbaby.com both -> 177.7.58.66
# ─────────────────────────────────────────────────────────────

# Bare domain -> redirect to www, preserving path/query.
yalamanbaby.com {
    redir https://www.yalamanbaby.com{uri} permanent
}

# www -> reverse proxy to the baby container's loopback port on the host.
www.yalamanbaby.com {
    encode gzip
    reverse_proxy 172.17.0.1:8088
}
