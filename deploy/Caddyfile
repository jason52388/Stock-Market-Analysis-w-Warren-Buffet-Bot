# SITE_HOSTNAME is the public hostname Caddy serves. Set in .env on the VPS.
# Caddy auto-provisions a Let's Encrypt cert as long as the hostname resolves
# to this VPS over public DNS.
{$SITE_HOSTNAME} {
    root * /srv
    encode gzip

    # Default to the landing page (index.html, regenerated by build-index.sh
    # after each weekly run).
    try_files {path} /index.html

    # Browseable archive directory.
    file_server browse

    # Light caching for HTML (so a redeploy shows new content within a minute).
    header /*.html Cache-Control "public, max-age=60"
    header /archive/* Cache-Control "public, max-age=3600"
}
