# Serves the site on both the bare domain and www. The apex redirects to www
# (the canonical address), so links and the cert stay consistent. Caddy
# auto-provisions Let's Encrypt certs for BOTH names — which requires BOTH
# yalamanstockmarket.com and www.yalamanstockmarket.com to have DNS A records
# pointing at this VPS (177.7.58.66).
#
# Hostnames are hardcoded (not {$SITE_HOSTNAME}) so an empty/missing env var
# can never produce an invalid empty site address that crashes Caddy.

# Bare domain -> redirect to www, preserving the path/query.
yalamanstockmarket.com {
    redir https://www.yalamanstockmarket.com{uri} permanent
}

# www -> the actual site.
www.yalamanstockmarket.com {
    root * /srv
    encode gzip

    # Default to the landing page (index.html, regenerated by build-index.sh
    # after each weekly run).
    try_files {path} /index.html

    # Only the archive directory gets a browseable index; everywhere else
    # serves explicit files only. This avoids exposing anything that lands in
    # out/ (debug CSVs, scratch files) on the public root.
    @archive path /archive /archive/*
    file_server @archive browse
    file_server

    # Light caching for HTML (so a redeploy shows new content within a minute).
    header /*.html Cache-Control "public, max-age=60"
    header /archive/* Cache-Control "public, max-age=3600"
}
